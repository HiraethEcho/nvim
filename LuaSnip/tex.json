    "body": "\\$\\mathbb{N\\}\\$"
  },
  "ZZ": {
    "prefix": "ZZ",
    "description": "integers",
    "body": "\\$\\mathbb{Z\\}\\$"
  },
  "QQ": {
    "prefix": "QQ",
    "description": "Rational number",
    "body": "\\$\\mathbb{Q\\}\\$"
  },
  "PP": {
    "prefix": "PP",
    "description": "Projectiv space",
    "body": "\\$\\mathbb{P\\}^{${1:n}\\}\\$"
  },
  "CC": {
    "prefix": "CC",
