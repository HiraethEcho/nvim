{
  "dm": {
    "prefix": "dm",
    "description": "displaymath",
    "body": [
      "\\$\\$",
      "$1",
      "\\$\\$"
    ]
  },
  "frac": {
    "prefix": "frac",
    "description": "Fraction",
    "body": "\\frac{$1\\}{$2\\}$0",
    "luasnip": {
      "autotrigger": true
    }
  },
  "\\\\\\": {
    "prefix": "\\\\\\",
    "description": "setminus",
    "body": "\\setminus"
  },
  "set": {
    "prefix": "set",
    "description": "set",
    "body": "\\{$1\\\\} $0"
  },
  "^^": {
    "prefix": "^^",
    "description": "super script ^{}",
    "body": "^{$1\\}$0",
    "luasnip": {
      "autotrigger": true
    }
  },
  "__": {
    "prefix": "__",
    "description": "sub script _{}",
    "body": "_{$1\\}$0",
    "luasnip": {
      "autotrigger": true
    }
  },
  "op": {
    "prefix": "op",
    "description": "operatorname",
    "body": "\\operatorname{${1:$TM_SELECTED_TEXT}\\}$0"
  },
  "Aa": {
    "prefix": "Aa",
    "description": "Affine space",
    "body": "\\$\\mathbb{A\\}^{${1:n}\\}\\$"
  },
  "RR": {
    "prefix": "RR",
