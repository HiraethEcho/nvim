endsnippet
snippet nn "cap" w
\cap 
endsnippet

snippet uu "cup" w
\cup 
endsnippet

snippet Uu "bigcup" w
\bigcup_{${1:i \in  I} }} $0
endsnippet

snippet Nn "bigcap" w
\bigcap_{${1:i \in ${2: I}} } $0
endsnippet

snippet vv "Vee" i
