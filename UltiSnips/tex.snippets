snippet case "cases" w
\begin{cases}
	$1 \\\\
	$2 \\\\
\end{cases}
$0
endsnippet

snippet ali "Align" b
\begin{align*}
	${1:${VISUAL}}
.\end{align*}
endsnippet

snippet ceil "Ceil" w
\left\lceil $1 \right\rceil $0
endsnippet

snippet floor "Floor" w
\left\lfloor $1 \right\rfloor$0
endsnippet

snippet pmat "pmat" i
\begin{pmatrix} $1 \end{pmatrix} $0
endsnippet

snippet bmat "bmat" i
\begin{bmatrix} $1 \end{bmatrix} $0
endsnippet

snippet set "set" w
\\{$1\\} $0
endsnippet
# }}} environment in math environment #

# }}} environment #

# single letter{{{ #

snippet Aa "Affine space" wA
\mathbb{A}^{${1:n}}
endsnippet

snippet RR "Real number" wA
\mathbb{R}
endsnippet

snippet FF "FF" wA
\mathbb{F}_{${1:n}}$0
endsnippet

snippet NN "Natural number" wA
\mathbb{N}
endsnippet

snippet ZZ "integers" wA
\mathbb{Z}
endsnippet

snippet QQ "Rational number" wA
\mathbb{Q}
endsnippet


snippet PP "Projectiv space" wA
\mathbb{P}^{${1:n}}
endsnippet

snippet CC "Complex number" wA
\mathbb{C}
endsnippet
# }}} single letter #

# sup and sub {{{ #
snippet __ "subscript" i
_{$1}$0
endsnippet

# context "math()"
snippet '([A-Za-z])([\d])' "auto subscript" wrA
`!p snip.rv = match.group(1)`_`!p snip.rv = match.group(2)`
endsnippet


context "math()"
snippet "([A-Za-z\]}'])([A-Za-z])\2{1}" "auto subscript" irA
`!p snip.rv = match.group(1)+'_{'+match.group(2)+'}'`
endsnippet

# context "math()"
snippet "([A-Za-z])(ii)" "auto subscript" irA
`!p snip.rv = match.group(1)`_{i}
endsnippet

# context "math()"
# snippet pf "pushforward" iA
# _{*}$0
# endsnippet

# context "math()"
# snippet "([A-Za-z])(kk)" "auto subscript" irA
# `!p snip.rv = match.group(1)`_{k}
# endsnippet

snippet ^^ "super script ^{}" i
^{$1}$0
endsnippet

snippet inv "inverse ^{-1}" i
^{-1$1}$0
endsnippet

context "math()"
snippet over "overset" wA
\overset{$1}{${VISUAL}}$0
endsnippet

context "math()"
snippet "([^\s]*)~~" "widetilde" riA
\widetilde{`!p snip.rv=match.group(1)`${VISUAL}}$0
endsnippet

context "math()"
snippet "([^\s]*)Bar" "Bar" riA
\overline{`!p snip.rv=match.group(1)`${VISUAL}}$0
endsnippet

context "math()"
snippet "([\w]*)bar" "bar" riA
\bar{`!p snip.rv=match.group(1)`${VISUAL}}$0
endsnippet

context "math()"
snippet "([^\s]*)Hat" "hat" riA
\widehat{`!p snip.rv=match.group(1)`${VISUAL}}$0
endsnippet

context "math()"
snippet "([\w]*)hat" "hat" riA
\hat{`!p snip.rv=match.group(1)`${VISUAL}}$0
endsnippet

